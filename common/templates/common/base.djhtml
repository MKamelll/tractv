<!DOCTYPE html>
<html lang="en">
    <head>
        {% load static %}
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="{% static "common/css/output.css" %}">
        <script src="{% static 'htmx.org/dist/htmx.min.js' %}"></script>
        <script defer src="{% static 'alpinejs/dist/cdn.min.js' %}"></script>
        <title>
            {% block title %}
                tractv
            {% endblock title %}
        </title>
    </head>
    <body>
        {% block body %}
        {% endblock body %}
    </body>
</html>
